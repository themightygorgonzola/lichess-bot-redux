# ═══════════════════════════════════════════════════════════════════════════
# LichessBotRedux — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Run the bot:
#   ..\make.ps1           (build + test + run)
#   ..\make.ps1 run       (just start)
# ═══════════════════════════════════════════════════════════════════════════

# ── Service tokens ────────────────────────────────────────────────────────
# At least one token is required. The bot connects to whichever services
# have a valid token configured.
#
# Lichess: https://lichess.org/account/oauth/token (Bot scope)
LICHESS_TOKEN=

# Chess.com: (placeholder — API key when Chess.com bot API becomes available)
# CHESSCOM_TOKEN=

# Self-play vs Stockfish: set to 'true' to enable the local Stockfish opponent.
# No account or token needed — Stockfish runs as a subprocess on your machine.
# SELFPLAY_ENABLED=true
# SELFPLAY_ENGINE=              # abs path to Stockfish binary (auto-detected if omitted)
# SELFPLAY_SF_THREADS=2         # threads for the Stockfish subprocess
# SELFPLAY_MOVETIME=500         # ms per Stockfish move (fixed-time games only)

# ── Engine ────────────────────────────────────────────────────────────────
# Path to engine binary, relative to this file (built into bot/engine/ by CMake)
ENGINE_PATH=./engine/lichess-bot.exe

# Path to NNUE weights file (optional — engine auto-discovers nn.bin next to binary)
EVAL_FILE=./engine/nn.bin

# Engine settings per game
ENGINE_MOVETIME=2000
ENGINE_THREADS=8
ENGINE_HASH=512

# ── Bot behaviour ─────────────────────────────────────────────────────────
# How many concurrent games to allow (1 = safest to start)
MAX_CONCURRENT_GAMES=1

# Dashboard HTTP port
DASHBOARD_PORT=3000

# Personality mode: 'full' (quotes + trash talk) or 'silent' (no chat)
PERSONALITY_MODE=silent

# Dynamic time management: 0.0 = impatient, 1.0 = maximum patience
THOUGHTFULNESS=0.7

# Enable pondering (think on opponent's time): true/false
PONDER=false

# ── PPM integration ───────────────────────────────────────────────────
# Set CONTROLLER_URL to enable PPM reporting (heartbeats + game events).
# Leave blank or unset to run without PPM.
CONTROLLER_URL=http://localhost:7000
PPM_BOT_NAME=lichess-bot
